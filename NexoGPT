<script>
(function(){
'use strict';

/* ══════════════════════════════════════════════
   PROTECTION LAYER — fixed false-positive bugs
   ══════════════════════════════════════════════
   Root causes of the "restricted access" bug:
   1. window.outerWidth - window.innerWidth > 160 fires on
      many normal browsers (toolbars, zoom levels, OS scaling)
   2. debugger timing check fires on slow/throttled machines
   3. console.log() trap fired unconditionally every 2s

   Fix: remove size-based body-wipe; keep key-wipe only;
   raise threshold and add a 3-strike debounce before acting.
   ══════════════════════════════════════════════ */

(function _devGuard(){
  var _strikes = 0;
  var _THRESHOLD = 300; // raised from 160 — avoids false positives on normal browsers

  function _wipeKey(){
    // Only disable the API key — do NOT wipe the DOM
    try{
      window.getApiKey = function(){ return ''; };
    }catch(e){}
  }

  function _check(){
    var wDiff = window.outerWidth  - window.innerWidth;
    var hDiff = window.outerHeight - window.innerHeight;
    if(wDiff > _THRESHOLD || hDiff > _THRESHOLD){
      _strikes++;
      if(_strikes >= 3){ _wipeKey(); } // 3 consecutive checks before acting
    } else {
      _strikes = 0; // reset on normal reading
    }
  }

  // Check on resize only — not on a rapid interval
