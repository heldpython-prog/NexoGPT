function parseMd(raw){
  if(!raw) return '';
  var codeBlocks=[];
  var t=raw.replace(/```([\w+#-]*)\n?([\s\S]*?)```/g,function(_,lang,code){var idx=codeBlocks.length;codeBlocks.push({lang:(lang||'').trim(),code:code});return '\x00CB'+idx+'\x00';});
  t=t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  t=t.replace(/`([^`\n]+)`/g,function(_,c){return '<code class="ic">'+c.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</code>';});
  t=t.replace(/^### (.+)$/gm,'<h3>$1</h3>');t=t.replace(/^## (.+)$/gm,'<h2>$1</h2>');t=t.replace(/^# (.+)$/gm,'<h1>$1</h1>');
  t=t.replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>');t=t.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');t=t.replace(/\*(.+?)\*/g,'<em>$1</em>');t=t.replace(/__(.+?)__/g,'<strong>$1</strong>');t=t.replace(/_([^_\n]+)_/g,'<em>$1</em>');
  t=t.replace(/^&gt; (.+)$/gm,'<blockquote>$1</blockquote>');t=t.replace(/<\/blockquote>\n<blockquote>/g,'<br>');
  t=t.replace(/^---$/gm,'<hr/>');
  t=t.replace(/(^[-*+] .+\n?)+/gm,function(block){var items=block.trim().split('\n').map(function(l){return '<li>'+l.replace(/^[-*+] /,'')+'</li>';});return '<ul>'+items.join('')+'</ul>';});
  t=t.replace(/(^\d+\. .+\n?)+/gm,function(block){var items=block.trim().split('\n').map(function(l){return '<li>'+l.replace(/^\d+\. /,'')+'</li>';});return '<ol>'+items.join('')+'</ol>';});
  t=t.replace(/!\[([^\]]*)\]\(([^)]+)\)/g,'<img src="$2" alt="$1" style="max-width:100%;border-radius:10px;margin:.5em 0;display:block" loading="lazy"/>');
  // Google Maps links → rich card
  t=t.replace(/\[([^\]]+)\]\((https:\/\/(?:www\.)?(?:maps\.google\.com|google\.com\/maps)[^)]+)\)/g,function(_,label,url){
    var clean=label.replace(/^[\s\uD800-\uDFFF\u2000-\u3300]+/,'').trim()||'Open in Maps';
    return '<a href="'+url+'" target="_blank" rel="noopener" class="map-card"><span class="map-card-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span><span class="map-card-label">'+escHtml(clean)+'</span><span class="map-card-ext"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></span></a>';
