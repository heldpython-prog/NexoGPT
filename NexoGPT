    if(m.role==='user'){
      var hasImg=m.imgs&&m.imgs.length>0;var hasPdf=m.pdfs&&m.pdfs.length>0;
      if(hasImg||hasPdf){var parts=[];if(m.imgs) m.imgs.forEach(function(im){var b64=im.url.split(',')[1];var mt=im.type||'image/jpeg';if(b64) parts.push({type:'image',source:{type:'base64',media_type:mt,data:b64}});});if(m.pdfs) m.pdfs.forEach(function(pdf){parts.push({type:'text',text:'[PDF: '+pdf.name+']\n'+pdf.text});});if(m.content) parts.push({type:'text',text:m.content});if(!parts.length) parts.push({type:'text',text:'(empty)'});out.push({role:'user',content:parts});}
