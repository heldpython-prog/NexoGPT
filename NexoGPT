    var lines=rawCode.split('\n');var lc=lines.length;var lineCountStr=lc>1?(lc+' lines'):'1 line';
    var isHtml=/^html?$/i.test(rawLang);var isSvg=/^svg$/i.test(rawLang);var canPreview=isHtml||isSvg;
