async function callClaude(msgs,model,system,maxTok,onToken,onDone,onError,onSearchStart,onSynthStart){
  var _hdr={'Content-Type':'application/json','x-api-key':getApiKey(),'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'};

  /* ── Real SSE streaming ── */
  async function streamFetch(payload, onChunk){
    var res = await fetch(_api,{method:'POST',headers:_hdr,body:JSON.stringify(Object.assign({stream:true},payload))});
    if(!res.ok){
      var errData = {};
      try{ errData = await res.json(); }catch(e){}
      if(res.status===401) throw new Error('Invalid API key.');
      if(res.status===429) throw new Error('__RATELIMIT__Too many requests. Please wait.||0');
      throw new Error((errData.error&&errData.error.message)||'API error '+res.status+'.');
    }
    var reader = res.body.getReader();
    var decoder = new TextDecoder();
    var buf = '';
    var accumulated = '';
    var toolUseBlock = null;
    var toolInputStr = '';
    var stopReason = null;
    var allContent = [];

    while(true){
      var _ref = await reader.read();
      if(_ref.done) break;
      buf += decoder.decode(_ref.value, {stream:true});
      var lines = buf.split('\n');
      buf = lines.pop(); // keep incomplete line
      for(var li=0;li<lines.length;li++){
        var line = lines[li].trim();
        if(!line || !line.startsWith('data:')) continue;
        var raw = line.slice(5).trim();
        if(raw==='[DONE]') break;
        var evt;
        try{ evt = JSON.parse(raw); }catch(e){ continue; }
        if(evt.type==='message_start') continue;
        if(evt.type==='content_block_start'){
          if(evt.content_block&&evt.content_block.type==='tool_use'){
            toolUseBlock = {id:evt.content_block.id,name:evt.content_block.name,input:{}};
            toolInputStr = '';
          }
        }
        if(evt.type==='content_block_delta'){
          var delta = evt.delta||{};
          if(delta.type==='text_delta'&&delta.text){
            accumulated += delta.text;
            onChunk(delta.text);
          }
          if(delta.type==='input_json_delta'&&delta.partial_json){
            toolInputStr += delta.partial_json;
          }
        }
        if(evt.type==='content_block_stop'){
          if(toolUseBlock){
            try{ toolUseBlock.input = JSON.parse(toolInputStr||'{}'); }catch(e){}
            allContent.push({type:'tool_use',id:toolUseBlock.id,name:toolUseBlock.name,input:toolUseBlock.input});
            toolUseBlock = null; toolInputStr = '';
          } else if(accumulated){
            allContent.push({type:'text',text:accumulated});
          }
        }
        if(evt.type==='message_delta'&&evt.delta&&evt.delta.stop_reason){
          stopReason = evt.delta.stop_reason;
        }
      }
    }
    return {accumulated:accumulated, stopReason:stopReason, allContent:allContent};
  }

  /* ── Non-streaming fallback (for web-search second pass) ── */
  async function doFetch(payload){
    var res=await fetch(_api,{method:'POST',headers:_hdr,body:JSON.stringify(payload)});
    var data=await res.json();
    if(!res.ok){
      if(res.status===401){throw new Error('Invalid API key.');}
      if(res.status===429){throw new Error('__RATELIMIT__Too many requests. Please wait.||0');}
      throw new Error((data&&data.error&&data.error.message)||'API error '+res.status+'.');
    }
    return data;
  }

  try{
    /* First pass: stream with web_search tool enabled */
    var result;
    var usedWebSearch = false;
    try{
      result = await streamFetch({model:model,max_tokens:maxTok,system:system,messages:msgs,tools:[{type:'web_search_20250305',name:'web_search'}]}, onToken);
    }catch(e1){
      if(String(e1.message).indexOf('__RATELIMIT__')!==-1||String(e1.message).indexOf('Invalid API')!==-1) throw e1;
      /* Fallback: stream without tools */
      result = await streamFetch({model:model,max_tokens:maxTok,system:system,messages:msgs}, onToken);
    }

    /* Web search tool use detected */
    if(result.stopReason==='tool_use'){
      var tb = result.allContent.find(function(b){return b.type==='tool_use'&&b.name==='web_search';});
      if(tb){
        var query = (tb.input&&tb.input.query)||'';
        if(onSearchStart) onSearchStart(query);
        /* Build follow-up messages with tool result */
        var assistantContent = result.allContent.length ? result.allContent : [{type:'text',text:result.accumulated}];
        var msgs2 = msgs.concat([
          {role:'assistant',content:assistantContent},
          {role:'user',content:[{type:'tool_result',tool_use_id:tb.id,content:'Search completed for: "'+query+'". Provide a thorough, well-cited answer using [Source](url) format.'}]}
        ]);
        await new Promise(function(r){setTimeout(r,350);});
        if(onSynthStart) onSynthStart();
        /* Stream the synthesis pass */
        var result2 = await streamFetch({model:model,max_tokens:Math.max(maxTok,4096),system:system,messages:msgs2,tools:[{type:'web_search_20250305',name:'web_search'}]}, onToken);
        onDone(result2.accumulated||'Web search returned no results.', query);
        return;
      }
    }

    onDone(result.accumulated||'_(empty response)_', '');
  }catch(e){ onError(e.message||'Network error.'); }
}

