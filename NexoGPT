  if(S.msgs.length<1) return;
  if(S.msgs[S.msgs.length-1].role==='assistant') S.msgs.pop();
  if(!S.msgs.length||S.msgs[S.msgs.length-1].role!=='user') return;
  // Fire the retry directly — bypasses the empty-textarea guard in sendMsg
  _doStream();
}

